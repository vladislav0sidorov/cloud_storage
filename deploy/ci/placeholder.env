# Копируется в cloud-server/.env только в CI (job «Docker — compose build»).
# Не использовать в продакшене на VPS.
PORT=4000
MONGODB_URI=mongodb://mongo:27017/cloud_storage
API_URL=http://localhost:4000
CLIENT_URL=http://localhost
ACCESS_TOKEN_SECRET=ci-placeholder-access-not-for-prod
REFRESH_TOKEN_SECRET=ci-placeholder-refresh-not-for-prod
SKIP_MAIL=true
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=ci@localhost
SMTP_PASSWORD=ci
