# Ручной запуск на VPS: скопируйте в .env рядом с docker-compose.yml.
# Деплой из GitHub Actions: см. deploy/docs/GITHUB_ENVIRONMENT.md (файл .env на VPS не обязателен).
#
# Префикс образов из GitHub Packages (имя репозитория в нижнем регистре).
# Пример: репозиторий github.com/MyUser/cloud_storage → ghcr.io/myuser/cloud_storage
GHCR_PREFIX=ghcr.io/ВАШ_ЛОГИН_НИЖНИЙ_РЕГИСТР/cloud_storage

# Публичный URL фронта (CORS): https://домен.ru или http://IP_СЕРВЕРА
CLIENT_URL=https://example.com

# Публичный URL API (письма активации, редиректы): обычно тот же хост, порт 4000 пока наружу не пускаем
API_URL=https://example.com:4000

PORT=4000

# Секреты сгенерируйте заново (openssl rand -hex 32)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# MongoDB внутри compose (по умолчанию); для Atlas подставьте свою строку и уберите сервис mongo из compose
MONGODB_URI=mongodb://mongo:27017/cloud_storage

# Почта (или SKIP_MAIL=true для отладки)
SKIP_MAIL=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
