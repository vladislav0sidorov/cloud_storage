{$DOMAIN} {
	encode zstd gzip

	# API: все запросы /api/* → в контейнер api (Express на 4000)
	# Важно: сохраняем префикс /api, т.к. backend роуты ожидают /api/...
	handle /api/* {
		reverse_proxy api:4000
	}

	# WebSocket (если используется): проксируем как есть
	@ws {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @ws api:4000

	# Frontend: всё остальное → nginx контейнер web
	reverse_proxy web:80
}

